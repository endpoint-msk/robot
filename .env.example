API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=123456:your_bot_token_here

# Через запятую — id групп/супергрупп/каналов, в которых бот работает.
# В остальных чатах бот молча игнорирует команды.
# Узнать id проще всего через @getmyid_bot или поставив бота в группу
# и посмотрев логи (msg.chat.id).
ALLOWED_CHATS=-1001234567890

# Куда складывать стейт (json-файл со сборами и сообщениями).
DATA_FILE=./data.json

# Опционально: автоматический форвардинг каждого нового поста из канала
# FORWARD_FROM_CHAT в чат FORWARD_TO_CHAT. Бот должен быть участником
# (или админом) исходного канала и иметь право писать в целевой чат.
# Если хотя бы одна переменная пустая — форвардинг выключен.
FORWARD_FROM_CHAT=
FORWARD_TO_CHAT=

# Опционально: id чата, в котором бот должен банить любого пытающегося
# зайти и удалять служебные сообщения о входе/кике. Бот должен быть
# админом этого чата с правом банить и удалять сообщения.
LIVE_CHAT_ID=

# Опционально: адрес 3D-принтера с Moonraker (Klipper) в локальной сети.
# Команда /printer показывает статус печати, прогресс и превью модели.
# Если переменная пустая — команда /printer отключена.
PRINTER_URL=http://192.168.2.40/

# Опционально: HTTP Basic-авторизация к принтеру в формате user:pass
# (например, если Moonraker за nginx с basic auth). Пусто — без авторизации.
PRINTER_AUTH=
