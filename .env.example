API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=123456:your_bot_token_here

# Через запятую — id групп/супергрупп/каналов, в которых бот работает.
# В остальных чатах бот молча игнорирует команды.
# Узнать id проще всего через @getmyid_bot или поставив бота в группу
# и посмотрев логи (msg.chat.id).
ALLOWED_CHATS=-1001234567890

# Куда складывать стейт (json-файл со сборами и сообщениями).
DATA_FILE=./data.json
