# --- Обязательные ---
API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=123456:your_bot_token_here

# Чаты, где бот работает (через запятую). В остальных — молчит.
ALLOWED_CHATS=-1001234567890

# --- Опциональные ---

# Файл стейта.
DATA_FILE=./data.json

# Форвардинг постов из канала в чат (нужны обе переменные).
FORWARD_FROM_CHAT=
FORWARD_TO_CHAT=

# Чат, где бот банит входящих и чистит служебные сообщения.
LIVE_CHAT_ID=

# 3D-принтер (Moonraker). Пусто — команда /printer выключена.
PRINTER_URL=http://192.168.2.40/
# Basic-авторизация к принтеру в формате user:pass.
PRINTER_AUTH=

# Роутер Keenetic для авто-отметок по MAC (нужны URL/LOGIN/PASSWORD).
KEENETIC_URL=http://192.168.1.1/
KEENETIC_LOGIN=admin
KEENETIC_PASSWORD=
# RCI-команда со списком хостов (по умолчанию show/ip/hotspot).
KEENETIC_RCI_PATH=show/ip/hotspot

# userId (через запятую) с доступом к отладочным командам (/forcemacupdate).
DEV_USER_IDS=

# --- Миниапп хостинга гостей ---
# Публичный HTTPS-адрес миниаппа. Пусто — вся подсистема хостинга выключена.
# Тот же URL укажи в BotFather (/mybots → Bot Settings → Configure Mini App →
# Enable Mini App), чтобы работали кнопки-ссылки t.me/<bot>?startapp в группах.
# Кнопку меню рядом с полем ввода бот ставит сам через API.
WEBAPP_URL=
# Хост/порт HTTP-сервера миниаппа (обычно за реверс-прокси с TLS).
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
# Usernames (через запятую, без @) с дев-режимом в миниаппе:
# кнопка-переключатель перспективы «резидент ↔ гость».
DEV_USERNAMES=
# Смещение пояса спейса от UTC в минутах — задаёт границы «дней» хостинга
# и понятие «сегодня» для уведомлений (180 = Москва).
HOSTING_TZ_OFFSET_MINUTES=180
